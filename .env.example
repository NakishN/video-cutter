# Скопируйте в .env и вставьте ключ из https://gen-api.ru/
GEN_API_KEY=sk-your-key-here

# Прокси для скачивания Twitch (yt-dlp):
# YTDLP_PROXY=direct          — всегда без прокси (если VPN выключен, но в системе задан ALL_PROXY)
# YTDLP_PROXY=socks5://127.0.0.1:10808  — явный адрес Clash/V2Ray
# (не задавайте — используется прокси из окружения; при Connection refused будет повтор без прокси)
